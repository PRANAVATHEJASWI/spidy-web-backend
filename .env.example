# Copy to .env for local dev. On Render, set these as actual env vars in
# the dashboard — do not upload this file with real values.

# "local" enables the local-JSON fallback if Firebase isn't configured.
# Any other value (e.g. "production") makes Firebase required — the app
# will return 503s on data endpoints instead of silently using disk.
ENVIRONMENT=local

# Paste the FULL service account JSON as a single-line string, e.g.:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
FIREBASE_CREDENTIALS_JSON=
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

PORT=8000
HOST=0.0.0.0
